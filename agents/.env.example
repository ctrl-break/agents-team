# ── SpecPipeline — Environment Configuration ──────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# Required:
OPENAI_API_KEY=YOUR_API_KEY

# Optional — Model selection:
# OPENAI_MODEL_NAME=gpt-4o
# MODEL=gpt-4o          # alias for OPENAI_MODEL_NAME
# LLM_PROVIDER=openai   # or anthropic, azure, etc.

# Optional — Pipeline behaviour:
# PIPELINE_MAX_ITERATIONS=3
# PIPELINE_REVIEW_SCORE_THRESHOLD=7.0
# PIPELINE_QUALITY_THRESHOLD_PCT=85.0
# PIPELINE_QA_MIN_COVERAGE_PCT=80.0
# PIPELINE_AUTO_APPROVE=false